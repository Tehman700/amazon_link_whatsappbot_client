# Core API (the deployed Vercel backend)
API_BASE=https://amazon-link-whatsappbot-client.vercel.app

# Status/pairing page
PORT=4000
# Anyone with this token can view the pairing QR — set something random!
STATUS_TOKEN=change-me

# Where WhatsApp session credentials are stored (survives restarts)
SESSION_DIR=./session

# pino log level: silent | error | warn | info | debug
LOG_LEVEL=warn
